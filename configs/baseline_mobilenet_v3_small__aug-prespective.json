{
    "model_name": "mobilenet_v3_small",
    "data_dir": ".",
    "splits_dir": "data/splits",
    "checkpoint_dir": "checkpoints/augmented_perspective",

    "hyperparameters": {
        "batch_size": 32,
        "num_epochs": 10,
        "learning_rate": 0.0001
    },

    "transformations": {
  "steps": [
    { "name": "random_rotation", "params": { "degrees": 8 } },
    { "name": "random_perspective", "params": { "distortion_scale": 0.2, "p": 0.3, "fill": 0} },
    { "name": "gaussian_blur", "params": { "kernel_size": 3, "sigma": [0.1, 0.8] } }
  ]
}
}